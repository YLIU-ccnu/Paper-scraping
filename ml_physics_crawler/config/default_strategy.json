    "phenomenology", "quantum field theory", "qft", "string theory", "effective field theory",
    "eft", "lattice qcd", "nuclear matter", "nuclear structure", "high-luminosity lhc", "lhc",
    "lhcb", "atlas", "cms", "alice", "sphenix", "eic", "electron ion collider",
